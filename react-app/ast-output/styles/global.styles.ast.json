{
  "fileName": "styles.css",
  "rules": [
    { "selector": "*", "properties": { "box-sizing": "border-box", "margin": "0", "padding": "0" } },
    { "selector": "body", "properties": { "font-family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif", "background": "var(--color-bg)", "color": "var(--color-text)", "font-size": "14px", "line-height": "1.4" } },
    { "selector": ".app-layout", "properties": { "display": "flex", "min-height": "100vh" } },
    { "selector": ".sidebar", "properties": { "width": "240px", "background": "var(--color-sidebar)", "color": "#b8c7d9", "display": "flex", "flex-direction": "column", "flex-shrink": "0", "position": "fixed", "top": "0", "left": "0", "bottom": "0", "z-index": "100" } },
    { "selector": ".sidebar-brand", "properties": { "padding": "20px 16px", "display": "flex", "align-items": "center", "gap": "10px", "border-bottom": "1px solid rgba(255,255,255,0.1)" } },
    { "selector": ".sidebar-brand-icon", "properties": { "width": "32px", "height": "32px", "background": "var(--color-primary)", "border-radius": "4px", "display": "flex", "align-items": "center", "justify-content": "center", "color": "#fff", "font-weight": "700", "font-size": "16px" } },
    { "selector": ".sidebar-brand-text", "properties": { "font-size": "15px", "font-weight": "600", "color": "#fff" } },
    { "selector": ".sidebar-nav", "properties": { "padding": "12px 0", "flex": "1" } },
    { "selector": ".sidebar-nav a", "properties": { "display": "flex", "align-items": "center", "gap": "12px", "padding": "8px 16px", "color": "#b8c7d9", "text-decoration": "none", "font-size": "14px", "font-weight": "500", "border-left": "3px solid transparent", "transition": "all 0.15s" } },
    { "selector": ".sidebar-nav a:hover", "properties": { "background": "var(--color-sidebar-hover)", "color": "#fff" } },
    { "selector": ".sidebar-nav a.active", "properties": { "background": "var(--color-sidebar-hover)", "color": "#fff", "border-left-color": "var(--color-primary)" } },
    { "selector": ".sidebar-nav-icon", "properties": { "font-size": "18px", "width": "20px", "text-align": "center" } },
    { "selector": ".main-content", "properties": { "margin-left": "240px", "flex": "1", "min-height": "100vh" } },
    { "selector": ".topbar", "properties": { "background": "var(--color-surface)", "border-bottom": "1px solid var(--color-border)", "padding": "0 32px", "height": "56px", "display": "flex", "align-items": "center", "justify-content": "space-between", "position": "sticky", "top": "0", "z-index": "50" } },
    { "selector": ".topbar-title", "properties": { "font-size": "20px", "font-weight": "600", "color": "var(--color-text)" } },
    { "selector": ".topbar-actions", "properties": { "display": "flex", "gap": "8px", "align-items": "center" } },
    { "selector": ".page-content", "properties": { "padding": "24px 32px", "max-width": "1200px" } },
    { "selector": ".card", "properties": { "background": "var(--color-surface)", "border-radius": "var(--radius)", "box-shadow": "var(--shadow-card)", "padding": "24px", "margin-bottom": "16px" } },
    { "selector": ".card-header", "properties": { "display": "flex", "align-items": "center", "justify-content": "space-between", "margin-bottom": "16px" } },
    { "selector": ".card-title", "properties": { "font-size": "16px", "font-weight": "600", "color": "var(--color-text)" } },
    { "selector": ".stats-row", "properties": { "display": "grid", "grid-template-columns": "repeat(4, 1fr)", "gap": "16px", "margin-bottom": "24px" } },
    { "selector": ".stat-card", "properties": { "background": "var(--color-surface)", "border-radius": "var(--radius)", "box-shadow": "var(--shadow-card)", "padding": "20px", "position": "relative", "overflow": "hidden" } },
    { "selector": ".stat-card::before", "properties": { "content": "''", "position": "absolute", "top": "0", "left": "0", "right": "0", "height": "3px" } },
    { "selector": ".stat-total::before", "properties": { "background": "var(--color-primary)" } },
    { "selector": ".stat-todo::before", "properties": { "background": "var(--color-todo-text)" } },
    { "selector": ".stat-progress::before", "properties": { "background": "var(--color-progress-text)" } },
    { "selector": ".stat-done::before", "properties": { "background": "var(--color-done-text)" } },
    { "selector": ".stat-value", "properties": { "font-size": "28px", "font-weight": "700", "margin-bottom": "4px" } },
    { "selector": ".stat-total .stat-value", "properties": { "color": "var(--color-primary)" } },
    { "selector": ".stat-todo .stat-value", "properties": { "color": "var(--color-todo-text)" } },
    { "selector": ".stat-progress .stat-value", "properties": { "color": "var(--color-progress-text)" } },
    { "selector": ".stat-done .stat-value", "properties": { "color": "var(--color-done-text)" } },
    { "selector": ".stat-label", "properties": { "font-size": "12px", "font-weight": "500", "color": "var(--color-text-subtle)", "text-transform": "uppercase", "letter-spacing": "0.5px" } },
    { "selector": ".badge", "properties": { "display": "inline-flex", "align-items": "center", "padding": "2px 8px", "border-radius": "3px", "font-size": "11px", "font-weight": "700", "text-transform": "uppercase", "letter-spacing": "0.5px" } },
    { "selector": ".badge-todo", "properties": { "background": "var(--color-todo)", "color": "var(--color-todo-text)" } },
    { "selector": ".badge-in_progress", "properties": { "background": "var(--color-progress)", "color": "var(--color-progress-text)" } },
    { "selector": ".badge-done", "properties": { "background": "var(--color-done)", "color": "var(--color-done-text)" } },
    { "selector": ".badge-high", "properties": { "background": "var(--color-high)", "color": "var(--color-high-text)" } },
    { "selector": ".badge-medium", "properties": { "background": "var(--color-medium)", "color": "var(--color-medium-text)" } },
    { "selector": ".badge-low", "properties": { "background": "var(--color-low)", "color": "var(--color-low-text)" } },
    { "selector": ".priority-icon", "properties": { "display": "inline-flex", "align-items": "center", "gap": "4px" } },
    { "selector": ".priority-icon::before", "properties": { "content": "''", "display": "inline-block", "width": "12px", "height": "12px", "border-radius": "2px" } },
    { "selector": ".priority-high::before", "properties": { "background": "#ff5630" } },
    { "selector": ".priority-medium::before", "properties": { "background": "#ff8b00" } },
    { "selector": ".priority-low::before", "properties": { "background": "#36b37e" } },
    { "selector": ".btn", "properties": { "display": "inline-flex", "align-items": "center", "gap": "6px", "padding": "6px 12px", "border": "none", "border-radius": "var(--radius)", "cursor": "pointer", "font-size": "14px", "font-weight": "500", "text-decoration": "none", "transition": "all 0.15s", "line-height": "20px" } },
    { "selector": ".btn-primary", "properties": { "background": "var(--color-primary)", "color": "#fff" } },
    { "selector": ".btn-primary:hover", "properties": { "background": "var(--color-primary-hover)" } },
    { "selector": ".btn-subtle", "properties": { "background": "transparent", "color": "var(--color-text-subtle)" } },
    { "selector": ".btn-subtle:hover", "properties": { "background": "rgba(9,30,66,0.08)", "color": "var(--color-text)" } },
    { "selector": ".btn-danger", "properties": { "background": "transparent", "color": "#bf2600" } },
    { "selector": ".btn-danger:hover", "properties": { "background": "#ffebe6" } },
    { "selector": ".btn-sm", "properties": { "padding": "4px 8px", "font-size": "12px" } },
    { "selector": ".task-table", "properties": { "width": "100%", "border-collapse": "collapse" } },
    { "selector": ".task-table th", "properties": { "text-align": "left", "padding": "8px 12px", "font-size": "11px", "font-weight": "600", "color": "var(--color-text-subtle)", "text-transform": "uppercase", "letter-spacing": "0.5px", "border-bottom": "2px solid var(--color-border)", "background": "#fafbfc" } },
    { "selector": ".task-table td", "properties": { "padding": "10px 12px", "border-bottom": "1px solid var(--color-border)", "font-size": "14px", "vertical-align": "middle" } },
    { "selector": ".task-table tr:hover td", "properties": { "background": "#fafbfc" } },
    { "selector": ".task-table .task-key", "properties": { "color": "var(--color-text-subtle)", "font-size": "12px", "font-weight": "500" } },
    { "selector": ".task-table .task-link", "properties": { "color": "var(--color-text)", "text-decoration": "none", "font-weight": "500" } },
    { "selector": ".task-table .task-link:hover", "properties": { "color": "var(--color-primary)", "text-decoration": "underline" } },
    { "selector": ".board", "properties": { "display": "flex", "gap": "12px", "overflow-x": "auto", "padding-bottom": "16px", "min-height": "400px" } },
    { "selector": ".board-column", "properties": { "flex": "1", "min-width": "280px", "background": "#ebecf0", "border-radius": "var(--radius)", "padding": "8px" } },
    { "selector": ".board-column-header", "properties": { "padding": "8px 8px 12px", "font-size": "12px", "font-weight": "600", "text-transform": "uppercase", "letter-spacing": "0.5px", "color": "var(--color-text-subtle)", "display": "flex", "align-items": "center", "justify-content": "space-between" } },
    { "selector": ".board-column-count", "properties": { "background": "rgba(9,30,66,0.08)", "border-radius": "10px", "padding": "2px 8px", "font-size": "12px", "font-weight": "600", "color": "var(--color-text-subtle)" } },
    { "selector": ".board-card", "properties": { "background": "var(--color-surface)", "border-radius": "var(--radius)", "box-shadow": "var(--shadow-card)", "padding": "12px", "margin-bottom": "8px", "cursor": "pointer", "transition": "box-shadow 0.15s" } },
    { "selector": ".board-card:hover", "properties": { "box-shadow": "var(--shadow-overlay)" } },
    { "selector": ".board-card-title", "properties": { "font-size": "14px", "font-weight": "500", "color": "var(--color-text)", "margin-bottom": "8px", "text-decoration": "none", "display": "block" } },
    { "selector": ".board-card-title:hover", "properties": { "color": "var(--color-primary)" } },
    { "selector": ".board-card-footer", "properties": { "display": "flex", "align-items": "center", "justify-content": "space-between" } },
    { "selector": ".board-card-meta", "properties": { "display": "flex", "align-items": "center", "gap": "8px" } },
    { "selector": ".avatar", "properties": { "width": "24px", "height": "24px", "border-radius": "50%", "background": "var(--color-primary)", "color": "#fff", "display": "inline-flex", "align-items": "center", "justify-content": "center", "font-size": "11px", "font-weight": "600" } },
    { "selector": ".form-group", "properties": { "margin-bottom": "16px" } },
    { "selector": ".form-group label", "properties": { "display": "block", "font-size": "12px", "font-weight": "600", "color": "var(--color-text-subtle)", "margin-bottom": "4px", "text-transform": "uppercase", "letter-spacing": "0.5px" } },
    { "selector": ".form-control", "properties": { "width": "100%", "padding": "8px 10px", "border": "2px solid var(--color-border)", "border-radius": "var(--radius)", "font-size": "14px", "font-family": "inherit", "background": "var(--color-bg)", "transition": "border-color 0.15s" } },
    { "selector": ".form-control:focus", "properties": { "outline": "none", "border-color": "var(--color-primary)", "background": "#fff" } },
    { "selector": "textarea.form-control", "properties": { "resize": "vertical", "min-height": "100px" } },
    { "selector": ".form-row", "properties": { "display": "grid", "grid-template-columns": "1fr 1fr", "gap": "16px" } },
    { "selector": ".form-actions", "properties": { "display": "flex", "gap": "8px", "margin-top": "24px", "padding-top": "16px", "border-top": "1px solid var(--color-border)" } },
    { "selector": ".filters-bar", "properties": { "display": "flex", "align-items": "center", "gap": "8px", "padding": "12px 0", "flex-wrap": "wrap" } },
    { "selector": ".filter-select", "properties": { "padding": "6px 10px", "border": "2px solid var(--color-border)", "border-radius": "var(--radius)", "font-size": "13px", "background": "var(--color-surface)", "color": "var(--color-text)", "cursor": "pointer" } },
    { "selector": ".filter-select:focus", "properties": { "outline": "none", "border-color": "var(--color-primary)" } },
    { "selector": ".filter-label", "properties": { "font-size": "12px", "font-weight": "600", "color": "var(--color-text-subtle)", "text-transform": "uppercase" } },
    { "selector": ".detail-header", "properties": { "margin-bottom": "24px" } },
    { "selector": ".detail-key", "properties": { "font-size": "13px", "color": "var(--color-text-subtle)", "font-weight": "500", "margin-bottom": "4px" } },
    { "selector": ".detail-title", "properties": { "font-size": "24px", "font-weight": "600", "color": "var(--color-text)" } },
    { "selector": ".detail-section", "properties": { "margin-bottom": "20px" } },
    { "selector": ".detail-section-title", "properties": { "font-size": "12px", "font-weight": "600", "color": "var(--color-text-subtle)", "text-transform": "uppercase", "letter-spacing": "0.5px", "margin-bottom": "8px" } },
    { "selector": ".detail-field label", "properties": { "font-size": "12px", "font-weight": "600", "color": "var(--color-text-subtle)", "text-transform": "uppercase", "letter-spacing": "0.5px" } },
    { "selector": ".detail-field p", "properties": { "font-size": "14px", "margin-top": "4px", "color": "var(--color-text)" } },
    { "selector": ".detail-description", "properties": { "font-size": "14px", "line-height": "1.6", "color": "var(--color-text)", "white-space": "pre-wrap" } },
    { "selector": ".status-buttons", "properties": { "display": "flex", "gap": "4px", "margin-top": "8px" } },
    { "selector": ".status-btn", "properties": { "padding": "4px 12px", "border": "2px solid var(--color-border)", "border-radius": "var(--radius)", "background": "var(--color-surface)", "font-size": "12px", "font-weight": "600", "cursor": "pointer", "text-transform": "uppercase", "letter-spacing": "0.5px", "transition": "all 0.15s" } },
    { "selector": ".status-btn:hover", "properties": { "border-color": "var(--color-primary)", "color": "var(--color-primary)" } },
    { "selector": ".status-btn.active", "properties": { "background": "var(--color-primary)", "color": "#fff", "border-color": "var(--color-primary)" } },
    { "selector": ".alert", "properties": { "padding": "12px 16px", "border-radius": "var(--radius)", "margin-bottom": "16px", "font-size": "14px" } },
    { "selector": ".alert-success", "properties": { "background": "var(--color-done)", "color": "var(--color-done-text)" } },
    { "selector": ".alert-error", "properties": { "background": "var(--color-high)", "color": "var(--color-high-text)" } },
    { "selector": ".empty-state", "properties": { "text-align": "center", "padding": "48px 24px", "color": "var(--color-text-subtle)" } },
    { "selector": ".empty-state-icon", "properties": { "font-size": "48px", "margin-bottom": "12px", "opacity": "0.5" } },
    { "selector": ".empty-state-text", "properties": { "font-size": "16px", "margin-bottom": "16px" } },
    { "selector": ".tech-stack", "properties": { "display": "flex", "flex-direction": "column", "gap": "20px" } },
    { "selector": ".tech-tier-label", "properties": { "font-size": "11px", "font-weight": "700", "text-transform": "uppercase", "letter-spacing": "0.8px", "color": "var(--color-text-subtle)", "margin-bottom": "8px" } },
    { "selector": ".tech-chips", "properties": { "display": "flex", "flex-wrap": "wrap", "gap": "8px" } },
    { "selector": ".tech-chip", "properties": { "display": "inline-flex", "align-items": "center", "gap": "6px", "padding": "6px 12px", "background": "var(--color-bg)", "border": "1px solid var(--color-border)", "border-radius": "16px", "font-size": "13px", "font-weight": "500", "color": "var(--color-text)" } },
    { "selector": ".tech-chip-dot", "properties": { "width": "8px", "height": "8px", "border-radius": "50%", "flex-shrink": "0" } },
    { "selector": ".tech-endpoints", "properties": { "display": "flex", "flex-direction": "column", "gap": "4px" } },
    { "selector": ".tech-endpoints code", "properties": { "display": "block", "padding": "6px 12px", "background": "#1e293b", "color": "#e2e8f0", "border-radius": "var(--radius)", "font-family": "'SF Mono', 'Fira Code', monospace", "font-size": "12px" } }
  ],
  "mediaQueries": [],
  "cssVariables": [
    { "name": "--color-bg", "value": "#f4f5f7" },
    { "name": "--color-surface", "value": "#fff" },
    { "name": "--color-sidebar", "value": "#0c2340" },
    { "name": "--color-sidebar-hover", "value": "#1a3a5c" },
    { "name": "--color-sidebar-active", "value": "#0052cc" },
    { "name": "--color-primary", "value": "#0052cc" },
    { "name": "--color-primary-hover", "value": "#0747a6" },
    { "name": "--color-text", "value": "#172b4d" },
    { "name": "--color-text-subtle", "value": "#5e6c84" },
    { "name": "--color-border", "value": "#dfe1e6" },
    { "name": "--color-todo", "value": "#dfe1e6" },
    { "name": "--color-todo-text", "value": "#42526e" },
    { "name": "--color-progress", "value": "#deebff" },
    { "name": "--color-progress-text", "value": "#0052cc" },
    { "name": "--color-done", "value": "#e3fcef" },
    { "name": "--color-done-text", "value": "#006644" },
    { "name": "--color-high", "value": "#ffebe6" },
    { "name": "--color-high-text", "value": "#bf2600" },
    { "name": "--color-medium", "value": "#fff7e6" },
    { "name": "--color-medium-text", "value": "#ff8b00" },
    { "name": "--color-low", "value": "#e3fcef" },
    { "name": "--color-low-text", "value": "#006644" },
    { "name": "--radius", "value": "3px" },
    { "name": "--shadow-card", "value": "0 1px 2px rgba(9,30,66,0.25)" },
    { "name": "--shadow-overlay", "value": "0 4px 8px -2px rgba(9,30,66,0.25), 0 0 1px rgba(9,30,66,0.31)" }
  ],
  "keyframes": []
}
