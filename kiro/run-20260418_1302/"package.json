{
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --coverage --ci --testResultsProcessor=jest-junit --coverageReporters=text-lcov",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "test:integration": "jest --config=jest.integration.config.js",
    "test:e2e": "cypress run",
    "test:e2e:ci": "start-server-and-test start http://localhost:3000 'cypress run --record'",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --format json --output-file test-results/eslint/eslint-report.json",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,json,css,md}",
    "format:check": "prettier --check src/**/*.{js,jsx,ts,tsx,json,css,md}",
    "deploy": "aws s3 sync build/ s3://$WEBSITE_BUCKET_NAME --delete",
    "invalidate": "aws cloudfront create-invalidation --distribution-id $DISTRIBUTION_ID --paths '/*'"
  }
}